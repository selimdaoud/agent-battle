# Copy to .env and fill in values

# Binance API (read-only market data — no trading keys needed for sim)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# OpenAI (news signal classification)
OPENAI_API_KEY=

# Server
PORT=3001
WS_TOKEN=changeme

# Engine
CANDLE_INTERVAL=15m       # 1m | 5m | 15m | 1h
MODE=live                  # live | replay
REPLAY_SPEED=100           # only used when MODE=replay
REPLAY_FROM=               # ISO timestamp — leave blank for full history

# Agent pool
LIVE_AGENTS=2
PAPER_AGENTS=4
INITIAL_CAPITAL=5000       # per live agent

# Adaptation
ADAPT_TRIGGER_N=10         # exits before re-estimating config
ADAPT_COOLDOWN_M=20        # trades before a parameter can be updated again
PAPER_DISCOUNT=0.7         # weight of paper outcomes vs live outcomes

# News signal
NEWS_DECAY_HOURS=2
NEWS_SOURCES=binance,coindesk   # comma-separated
